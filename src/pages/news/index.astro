---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('news', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout
  title="News & Insights | Dunn Development"
  description="Commercial construction insights from the Dunn Development team — project management, tenant improvements, airport construction, and industry best practices."
>

  <section class="bg-gray-50 border-b border-gray-200 py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <p class="text-red-600 text-sm font-semibold uppercase tracking-widest mb-3">News & Insights</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-5">
        From the Field
      </h1>
      <p class="text-gray-600 text-lg">
        Construction management insights, industry perspective, and project guidance from the Dunn Development team.
      </p>
    </div>
  </section>

  <section class="py-20 px-6 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="divide-y divide-gray-200">
        {posts.map((post) => (
          <article class="py-10 group">
            <div class="flex flex-wrap gap-2 mb-4">
              {post.data.tags.map((tag) => (
                <span class="bg-gray-100 text-gray-600 text-xs font-semibold px-3 py-1 rounded-full">
                  {tag}
                </span>
              ))}
            </div>
            <a href={`/news/${post.slug}`} class="block">
              <h2 class="text-2xl font-extrabold text-gray-900 mb-3 group-hover:text-red-600 transition-colors leading-snug">
                {post.data.title}
              </h2>
            </a>
            <p class="text-gray-600 leading-relaxed mb-5">{post.data.description}</p>
            <div class="flex items-center justify-between">
              <div class="text-sm text-gray-400">
                {formatDate(post.data.publishDate)} &middot; {post.data.author}
              </div>
              <a href={`/news/${post.slug}`}
                class="text-red-600 text-sm font-semibold hover:underline">
                Read article →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</Layout>
